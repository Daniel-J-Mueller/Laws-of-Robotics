# Optional email configuration for Hermes aligned agent.
# Keep real secrets out of git. Load this with:
#   set -a; source .env; set +a
#
# Outlook SMTP defaults are already used by the runner:
#   HERMES_SMTP_HOST=smtp.office365.com
#   HERMES_SMTP_PORT=587
#
# You still need a valid mailbox username and password or app password.
HERMES_SMTP_USER=
HERMES_SMTP_PASSWORD=
HERMES_SMTP_FROM=

# Optional inbox support. If omitted, the runner reuses SMTP user/password.
#   HERMES_IMAP_HOST=outlook.office365.com
#   HERMES_IMAP_PORT=993
HERMES_IMAP_USER=
HERMES_IMAP_PASSWORD=

# Optional model overrides.
HERMES_MODEL=hermes3
HERMES_EMBED_MODEL=embeddinggemma
HERMES_EMAIL_TO=danieljmueller@outlook.com
